{
  "version": 8,
  "sources": {
    "saysheep-tiles": {
      "type": "vector",
      "url": "pmtiles://http://localhost:3008/map.pmtiles",
      "attribution": "© OpenStreetMap"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f0f2f5"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "saysheep-tiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#c8ddf0"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "saysheep-tiles",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#e2f0d9"
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "saysheep-tiles",
      "source-layer": "roads",
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 1.5,
          18, 12
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "saysheep-tiles",
      "source-layer": "buildings",
      "paint": {
        "fill-color": "#e0e0e0",
        "fill-opacity": 0.6
      }
    }
  ]
}